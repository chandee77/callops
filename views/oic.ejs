<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>IT Roster - OIC Control Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-200 font-sans p-8">
    <div class="max-w-6xl mx-auto">
        <header class="mb-8 flex justify-between items-center bg-blue-800 text-white p-6 rounded-lg shadow-lg">
            <div>
                <h1 class="text-2xl font-bold">OIC Operations Desk</h1>
                <p class="text-sm text-blue-200">Daily & Monthly Roster Management</p>
            </div>
            <a href="/logout" class="bg-red-500 px-4 py-2 rounded hover:bg-red-600 font-bold">Logout</a>
        </header>

        <section class="mb-8 bg-white p-6 rounded-lg shadow-sm border border-slate-200">
            <h2 class="text-xl font-bold text-slate-700 mb-4">👥 Active Staff Directory</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-slate-100 text-slate-600 text-sm uppercase">
                        <tr>
                            <th class="py-3 px-4 rounded-tl-lg">Officer ID</th>
                            <th class="py-3 px-4">Name</th>
                            <th class="py-3 px-4 text-center">Total Shifts Done</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% users.filter(u => u.isActive).forEach(user => { %>
                            <tr class="hover:bg-slate-50">
                                <td class="py-3 px-4 font-mono font-medium text-slate-800"><%= user.id %></td>
                                <td class="py-3 px-4 font-semibold"><%= user.name %></td>
                                <td class="py-3 px-4 text-center">
                                    <span class="bg-blue-100 text-blue-800 font-bold px-3 py-1 rounded-full text-sm">
                                        <%= user.totalShifts %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div class="bg-white p-6 rounded-lg shadow border-l-4 border-yellow-400">
                    <h2 class="text-xl font-semibold mb-4">Report Leave or Lock User</h2>
                    <form action="/api/unavailability" method="POST" class="flex flex-col gap-4">
                        <select name="userId" class="border p-2 rounded" required>
                            <option value="">-- Select Officer --</option>
                            <% users.filter(u => u.isActive).forEach(user => { %>
                                <option value="<%= user.id %>"><%= user.name %> (<%= user.id %>)</option>
                            <% }) %>
                        </select>
                        <input type="date" name="date" class="border p-2 rounded" required>
                        <select name="reason" class="border p-2 rounded" required>
                            <option value="LEAVE">Standard Leave</option>
                            <option value="ADMIN_LOCK">OIC Lock (Training/Discipline)</option>
                        </select>
                        <button type="submit" class="bg-yellow-500 text-white py-2 rounded font-bold">Apply & Auto-Reassign</button>
                    </form>
                </div>

                <div class="bg-white p-6 rounded-lg shadow border-l-4 border-red-400">
                    <h2 class="text-xl font-semibold mb-4">Declare Public Holiday</h2>
                    <form action="/api/holidays" method="POST" class="flex flex-col gap-4">
                        <input type="text" name="name" placeholder="Holiday Name (e.g. Poya)" class="border p-2 rounded" required>
                        <input type="date" name="date" class="border p-2 rounded" required>
                        <button type="submit" class="bg-red-500 text-white py-2 rounded font-bold">Register Holiday</button>
                    </form>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-white p-6 rounded-lg shadow border-l-4 border-purple-500">
                    <h2 class="text-xl font-semibold mb-2">Generate Entire Month</h2>
                    <form action="/api/generate-month" method="POST" class="flex flex-col gap-4">
                        <input type="month" name="monthYear" class="border p-2 rounded" required>
                        <button type="submit" class="bg-purple-600 text-white py-2 rounded font-bold hover:bg-purple-700">
                            Run Bulk Algorithm
                        </button>
                    </form>
                </div>

                <div class="bg-white p-6 rounded-lg shadow border-l-4 border-blue-400">
                    <h2 class="text-xl font-semibold mb-4">Onboard New Officer</h2>
                    <form action="/api/users" method="POST" class="flex flex-col gap-4">
                        <input type="text" name="id" placeholder="ID (e.g. IT04)" class="border p-2 rounded" required>
                        <input type="text" name="name" placeholder="Full Name" class="border p-2 rounded" required>
                        <button type="submit" class="bg-blue-500 text-white py-2 rounded font-bold">Add to System</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>